# Template de variáveis de PRODUÇÃO — copie para .env.prod e preencha.
# NUNCA versionar o .env.prod com valores reais (já está no .gitignore).

# Senha do PostgreSQL (gere uma forte: openssl rand -base64 24)
DB_PASSWORD=

# Segredo do JWT (gere: openssl rand -hex 32)
JWT_SECRET=

# Expiração do token em minutos (480 = 8h)
JWT_EXPIRES_MIN=480

# Ambiente
ENV=prod
