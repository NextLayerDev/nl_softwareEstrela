# Template de variáveis de PRODUÇÃO — copie para .env.prod e preencha.
# NUNCA versionar o .env.prod com valores reais (já está no .gitignore).
# Suba com: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# Senha do PostgreSQL (gere uma forte: openssl rand -base64 24). NÃO use 'senha'.
DB_PASSWORD=

# Segredo do JWT (gere: openssl rand -hex 32). Mínimo 32 caracteres — o startup recusa
# valores fracos/de exemplo quando ENV=prod.
JWT_SECRET=

# Expiração do token em minutos (120 = 2h)
JWT_EXPIRES_MIN=120

# Ambiente
ENV=prod

# Imagem que este servidor roda. SEMPRE uma tag imutável (vX.Y.Z) — nunca :latest, senão
# um `up -d` casual puxaria versão nova sem ninguém clicar em nada, e o rollback viraria
# uma corrida contra a tag. Quem reescreve isto é o agente de deploy, em
# /var/lib/estrela-agente/env.tag; aqui fica só o valor inicial.
# O pacote no GHCR é PÚBLICO: não é preciso `docker login` nem token neste servidor.
APP_IMAGEM=ghcr.io/nextlayerdev/nl_softwareestrela:v0.1.0

# Hosts aceitos pelo TrustedHostMiddleware. "*" desliga a checagem (padrão atual).
# Para restringir, inclua SEMPRE o loopback: o healthcheck do container bate em 127.0.0.1
# e, sem ele na lista, o container nunca fica healthy e o Caddy não sobe.
# Ex.: ALLOWED_HOSTS=sistema.local,127.0.0.1,localhost
ALLOWED_HOSTS=*

# Storage de imagens (MinIO). O bucket deve ser PRIVADO (imagens via URL assinada).
# Rotacione a chave se ela já foi exposta em algum .env.
S3_ENDPOINT_URL=
S3_PUBLIC_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=estrela-uploads
