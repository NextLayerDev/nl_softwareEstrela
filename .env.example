JWT_EXPIRES_MIN=480
ENV=dev

# Storage de imagens (MinIO). Na VPS (EasyPanel), use o hostname interno do serviço em
# S3_ENDPOINT_URL (ex.: http://api-nextpy_minio:9000) para não sair da rede. Em dev local,
# use o domínio público (o mesmo do S3_PUBLIC_URL) já que a máquina não acessa a rede interna.
S3_ENDPOINT_URL=https://api-nextpy-minio.1nwz76.easypanel.host
S3_PUBLIC_URL=https://api-nextpy-minio.1nwz76.easypanel.host
S3_ACCESS_KEY=troque-isto
S3_SECRET_KEY=troque-isto
S3_BUCKET=estrela-uploads
