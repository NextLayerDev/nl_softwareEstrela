# Agente de deploy do Estrela Gestão.
# Instalar em /etc/systemd/system/estrela-agente.service (ver deploy/instalar-agente.sh).
#
#   systemctl daemon-reload && systemctl enable --now estrela-agente
#   systemctl status estrela-agente && journalctl -u estrela-agente -f
#
# Este processo é o ÚNICO componente do sistema que fala com o Docker. O container do app
# não recebe o socket de propósito: com ele, qualquer RCE numa web app que aceita upload
# de XLSX viraria root no host. Toda a separação de privilégio do deploy depende deste
# arquivo estar certo — e ele tem várias armadilhas que só aparecem em produção.

[Unit]
Description=Agente de deploy do Estrela Gestão (pull-based, via Postgres LISTEN)
Documentation=file:/opt/estrela/scripts/agente/agente.py
# O agente precisa do Docker: sem isto, no boot do mini PC ele sobe antes do dockerd,
# falha no primeiro `docker compose ps` e queima o StartLimit antes de o host terminar
# de acordar.
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

# ATENÇÃO: StartLimitIntervalSec e StartLimitBurst vão em [Unit], NÃO em [Service].
# Colocá-las em [Service] é o erro clássico: o systemd IGNORA em silêncio (não é erro de
# sintaxe, a unidade sobe normal), e o rate limit fica valendo o default. Como o agente
# nunca deve morrer sozinho, o limite existe só para um crashloop de verdade (config
# quebrada) não fritar o disco com log.
StartLimitIntervalSec=300
StartLimitBurst=10

[Service]
Type=simple
User=estrela-agente
Group=estrela-agente
# Grupo docker: é o privilégio real deste serviço. Equivale a root no host — daí todo o
# resto do hardening abaixo.
SupplementaryGroups=docker

EnvironmentFile=/etc/estrela-agente/agente.env
ExecStart=/opt/estrela-agente/venv/bin/python /opt/estrela-agente/agente.py

# Restart=always e não on-failure: o agente sai com 0 ao receber SIGTERM, mas se ele sair
# por qualquer outro motivo (bug, OOM), tem que voltar. Um agente morto não dá erro em
# lugar nenhum — os botões da aba /deploy simplesmente não fazem nada, e ninguém descobre
# até precisar de um deploy urgente. A sonda de heartbeat na tela existe por isso.
Restart=always
RestartSec=10
TimeoutStopSec=60
KillSignal=SIGTERM

# --- Diretórios ------------------------------------------------------------
# RuntimeDirectory cria /run/estrela-agente (0700, dono estrela-agente) e o remove no
# stop. É obrigatório por causa da combinação abaixo: o usuário é --no-create-home, e com
# ProtectHome=true + ProtectSystem=strict o docker CLI não acha onde escrever o
# ~/.docker/config.json e falha com um erro de permissão que não parece ter nada a ver
# com isso. HOME e DOCKER_CONFIG precisam apontar para um lugar gravável de verdade.
RuntimeDirectory=estrela-agente
RuntimeDirectoryMode=0700
Environment=HOME=/run/estrela-agente
Environment=DOCKER_CONFIG=/run/estrela-agente/.docker
Environment=XDG_RUNTIME_DIR=/run/estrela-agente
Environment=PYTHONUNBUFFERED=1

StateDirectory=estrela-agente
StateDirectoryMode=0750
WorkingDirectory=/var/lib/estrela-agente

# --- Hardening -------------------------------------------------------------
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
ProtectProc=invisible
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=no
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6

# Capabilities zeradas: o agente não precisa de NENHUMA. Ele não abre porta baixa, não
# monta nada, não muda de usuário — quem faz o trabalho privilegiado é o dockerd, do
# outro lado do socket.
# CONSEQUÊNCIA PRÁTICA: sem CAP_NET_RAW, `ping` NÃO funciona aqui. Por isso o agente
# detecta internet com socket.create_connection() e nunca com ping — a sonda diria "sem
# internet" num servidor perfeitamente conectado e todo deploy morreria antes de começar.
CapabilityBoundingSet=
AmbientCapabilities=

# @privileged/@obsolete/@resources fora. Não use um filtro mais apertado sem testar: o
# psycopg (libpq) e o docker CLI (Go runtime) usam mais syscalls do que parece.
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM
SystemCallArchitectures=native

# ProtectSystem=strict deixa TODO o sistema de arquivos read-only. O que o agente escreve
# precisa ser liberado aqui — e a regra é liberar DIRETÓRIO, nunca arquivo:
# escrever /var/lib/estrela-agente/env.tag usa os.replace(), que é rename(2), que exige
# permissão de escrita no DIRETÓRIO. Um ReadWritePaths apontando para o arquivo env.tag
# deixaria a gravação atômica falhar com EROFS/EACCES — e a gravação atômica é o que
# impede um `up -d` de ler o arquivo pela metade e subir com APP_IMAGEM vazio.
ReadWritePaths=/var/lib/estrela-agente
#
# /opt/estrela NÃO entra aqui, de propósito. Dar escrita lá daria ao agente poder de
# reescrever o próprio docker-compose.prod.yml — e um compose gravável por quem tem o
# socket do Docker é a separação de privilégio inteira virando decoração (bastaria
# acrescentar `volumes: [/:/host]` ao serviço app). O agente LÊ o compose e o .env.prod;
# o único arquivo que ele escreve é o env.tag, no diretório dele.

# Log vai para o journal.
StandardOutput=journal
StandardError=journal
SyslogIdentifier=estrela-agente

[Install]
WantedBy=multi-user.target
